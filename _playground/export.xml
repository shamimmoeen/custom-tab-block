        <content:encoded><![CDATA[<!-- wp:create-block/custom-tab-block {"tab1Image":11,"tab1ImageUrl":"https://raw.githubusercontent.com/shamimmoeen/custom-tab-block/master/assets/demo/chapel.jpg","tab1ImageAlt":"Small white alpine chapel in a green meadow beneath the Dolomite peaks","tab1Title":"Mountain Chapel","tab1Description":"A small white alpine chapel with a steeply pitched roof sits in a green meadow beneath the rugged peaks of the Dolomites.","tab1Link":"https://www.pexels.com/photo/charming-mountain-chapel-in-the-dolomites-36369882/","tab2Image":12,"tab2ImageUrl":"https://raw.githubusercontent.com/shamimmoeen/custom-tab-block/master/assets/demo/bikes.jpg","tab2ImageAlt":"Two bicycles on a gravel path beside a river, framed by trees","tab2Title":"Lakeside Trail","tab2Description":"Two bicycles lean against each other on a gravel path beside a quiet river. Tall trees line the bank, and soft evening light filters through the leaves.","tab2Link":"https://www.pexels.com/photo/bikes-parked-by-a-river-26744424/"} -->
<div class="wp-block-create-block-custom-tab-block custom-tab-block"><div class="custom-tab-block__tablist" role="tablist" aria-label="Tabs"><button type="button" class="custom-tab-block__tab" role="tab" aria-label="Tab 1: Mountain Chapel" aria-selected="true"><img src="https://raw.githubusercontent.com/shamimmoeen/custom-tab-block/master/assets/demo/chapel.jpg" alt="Small white alpine chapel in a green meadow beneath the Dolomite peaks" class="wp-image-11 custom-tab-block__tab-image"/><span class="custom-tab-block__tab-number">01</span></button><button type="button" class="custom-tab-block__tab" role="tab" aria-label="Tab 2: Lakeside Trail" aria-selected="false"><img src="https://raw.githubusercontent.com/shamimmoeen/custom-tab-block/master/assets/demo/bikes.jpg" alt="Two bicycles on a gravel path beside a river, framed by trees" class="wp-image-12 custom-tab-block__tab-image"/><span class="custom-tab-block__tab-number">02</span></button></div><div class="custom-tab-block__panel" role="tabpanel" tabindex="0"><p class="custom-tab-block__text"><strong class="custom-tab-block__title">Mountain Chapel</strong><span class="custom-tab-block__description">A small white alpine chapel with a steeply pitched roof sits in a green meadow beneath the rugged peaks of the Dolomites.</span></p><div class="custom-tab-block__actions"><a class="custom-tab-block__button wp-element-button" href="https://www.pexels.com/photo/charming-mountain-chapel-in-the-dolomites-36369882/" aria-label="Read More about Mountain Chapel">Read More</a></div></div><div class="custom-tab-block__panel" hidden role="tabpanel" tabindex="0"><p class="custom-tab-block__text"><strong class="custom-tab-block__title">Lakeside Trail</strong><span class="custom-tab-block__description">Two bicycles lean against each other on a gravel path beside a quiet river. Tall trees line the bank, and soft evening light filters through the leaves.</span></p><div class="custom-tab-block__actions"><a class="custom-tab-block__button wp-element-button" href="https://www.pexels.com/photo/bikes-parked-by-a-river-26744424/" aria-label="Read More about Lakeside Trail">Read More</a></div></div></div>
<!-- /wp:create-block/custom-tab-block -->]]></content:encoded>
