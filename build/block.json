{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "create-block/custom-tab-block",
  "version": "0.1.0",
  "title": "Custom Tab Block",
  "category": "widgets",
  "icon": "smiley",
  "description": "Example block scaffolded with Create Block tool.",
  "example": {},
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": false,
      "text": true
    },
    "html": false,
    "typography": {
      "fontSize": true
    }
  },
  "attributes": {
    "showStartingYear": {
      "type": "boolean"
    },
    "startingYear": {
      "type": "string"
    }
  },
  "textdomain": "custom-tab-block",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}