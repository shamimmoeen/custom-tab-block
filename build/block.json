{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "create-block/custom-tab-block",
  "version": "0.3.0",
  "title": "Custom Tab Block",
  "category": "widgets",
  "icon": "smiley",
  "description": "Accessible tabbed content with image-backed tabs.",
  "example": {},
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ]
    },
    "html": false
  },
  "attributes": {
    "tablistLabel": {
      "type": "string",
      "default": "Tabs"
    },
    "tab1Image": {
      "type": "integer"
    },
    "tab1ImageUrl": {
      "type": "string"
    },
    "tab1ImageAlt": {
      "type": "string",
      "default": ""
    },
    "tab1Title": {
      "type": "string",
      "default": "Mountain Chapel"
    },
    "tab1Description": {
      "type": "string",
      "default": "A small white alpine chapel with a steeply pitched roof sits in a green meadow beneath the rugged peaks of the Dolomites."
    },
    "tab1Link": {
      "type": "string",
      "default": "https://wordpress.org/"
    },
    "tab2Image": {
      "type": "integer"
    },
    "tab2ImageUrl": {
      "type": "string"
    },
    "tab2ImageAlt": {
      "type": "string",
      "default": ""
    },
    "tab2Title": {
      "type": "string",
      "default": "Lakeside Trail"
    },
    "tab2Description": {
      "type": "string",
      "default": "Two bicycles lean against each other on a gravel path beside a quiet river. Tall trees line the bank, and soft evening light filters through the leaves."
    },
    "tab2Link": {
      "type": "string",
      "default": "https://wordpress.org/"
    }
  },
  "textdomain": "custom-tab-block",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}